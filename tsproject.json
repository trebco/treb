{
  "compilerOptions": {
    "declaration": true,
    "target": "esnext",
    "module": "esnext",
    "moduleResolution": "bundler",
    "strict": true,
    "composite": true,
    "outDir": "./build",
    "experimentalDecorators": true,
    "sourceMap": true,
    "resolveJsonModule": true,
    "rootDir": ".",
    "importHelpers": true,
    "noEmitHelpers": true,
    "verbatimModuleSyntax": true,
    "types": ["node"],
    "lib": [
      "dom", "esnext", "dom.iterable"
    ],
    "allowSyntheticDefaultImports": true,
    "esModuleInterop": true
  },
  "exclude": [
    "node_modules"
  ]
}
